# Environment Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=True

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_key_here
WEBHOOK_ENDPOINT=/webhook-endpoint

# Confluence Configuration (if needed)
CONFLUENCE_URL=https://your-confluence-instance.atlassian.net
CONFLUENCE_USER=your_user_email
CONFLUENCE_API_TOKEN=your_api_token
CONFLUENCE_PAGE_URL=https://your-confluence-instance.atlassian.net/wiki/spaces/SPACE/pages/123456/Page+Title
CONFLUENCE_WATCH_INTERVAL=60



# Jira Configuration (optional; defaults to the Confluence values above)
JIRA_URL=https://your-jira-instance.atlassian.net
JIRA_USER=your_user_email
JIRA_API_TOKEN=your_api_token

# Microsoft Graph Configuration
MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MS_GRAPH_ACCESS_TOKEN=your_access_token

# Weekly Executive Report Runner
WEEKLY_REPORT_SOURCE_PAGE_URL=https://your-confluence-instance.atlassian.net/wiki/spaces/SPACE/pages/123456/PI+Feature+Development
WEEKLY_REPORT_TEMPLATE_ID=
WEEKLY_REPORT_TEMPLATE_NAME=Weekly Executive Report
WEEKLY_REPORT_TEMPLATE_SPACE_KEY=
WEEKLY_REPORT_OUTPUT_PARENT_PAGE_URL=
WEEKLY_REPORT_OUTPUT_SPACE_KEY=
WEEKLY_REPORT_TITLE_PREFIX=Weekly Executive Report
WEEKLY_REPORT_INTERVAL_SECONDS=604800

# Atlassian MCP / LangGraph Agent
ATLASSIAN_MCP_SERVER=atlassian_mcp_server.py
ATLASSIAN_AGENT_RECURSION_LIMIT=25
ATLASSIAN_AGENT_HISTORY_LIMIT=12
SHOW_TOOL_IO=false

# Application
APP_NAME=Confluence Webhook Listener
LOG_LEVEL=INFO
